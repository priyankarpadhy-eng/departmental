rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // --- PUBLIC COLLECTIONS --- (Readable by anyone for landing page)
    
    match /settings/landing {
      allow read: if true;
    }
    
    match /news_events/{id} {
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('hod');
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('hod');
    }
    
    match /gallery/{id} {
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('hod');
    }
    
    match /departments/{id} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // Profiles: Shared rules for Public vs Private visibility
    match /profiles/{userId} {
      // Allow public to read faculty profiles for landing page
      allow read: if true; 
      allow write: if hasRole('admin') || request.auth.uid == userId;
    }

    // --- PROTECTED COLLECTIONS --- (Requires Login)

    // Attendance System
    match /attendance_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty');
    }

    match /attendance_records/{recordId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty') || (isSignedIn() && request.resource.data.student_id == request.auth.uid);
    }

    match /attendance_summary/{summaryId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty') || (isSignedIn() && (resource == null || resource.data.student_id == request.auth.uid) && request.resource.data.student_id == request.auth.uid);
    }

    // Central Storage (B2 Integration)
    match /central_storage/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('faculty') || hasRole('admin');
    }

    // Academic Structure
    match /batches/{id} { allow read: if isSignedIn(); allow write: if hasRole('admin'); }
    match /semesters/{id} { allow read: if isSignedIn(); allow write: if hasRole('admin'); }
    match /courses/{id} { allow read: if isSignedIn(); allow write: if hasRole('admin'); }
    match /course_offerings/{id} { allow read: if isSignedIn(); allow write: if hasRole('admin'); }
    match /timetable_slots/{id} { allow read: if isSignedIn(); allow write: if hasRole('admin'); }

    // Social & Mentorship
    match /student_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.author_id == request.auth.uid || hasRole('admin'));
    }

    match /mentorship_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.student_id == request.auth.uid ||
        resource.data.alumni_id == request.auth.uid ||
        hasRole('admin') || hasRole('hod')
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.student_id == request.auth.uid ||
        resource.data.alumni_id == request.auth.uid ||
        hasRole('admin')
      );
    }

    // Resources & Classroom
    match /study_materials/{id} { allow read: if isSignedIn(); allow write: if hasRole('faculty') || hasRole('admin'); }
    match /materials/{id} { allow read: if isSignedIn(); allow write: if hasRole('faculty') || hasRole('admin'); }
    match /assignments/{id} { allow read: if isSignedIn(); allow write: if hasRole('faculty') || hasRole('admin'); }
    match /submissions/{id} { 
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.student_id == request.auth.uid || hasRole('faculty') || hasRole('admin'));
    }

    // Results & Gradebook
    match /results/{id} {
      allow read: if isSignedIn(); // alumni can read their historical results
      allow write: if hasRole('faculty') || hasRole('admin');
    }
    
    // Live Sessions
    match /live_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty');
    }

    // Requests & Approvals (Certificates, etc.)
    match /requests/{id} {
      allow read: if true; // Publicly readable for verification purposes
      allow create: if isSignedIn();
      allow update: if hasRole('admin') || hasRole('hod');
      allow delete: if hasRole('admin') || (isSignedIn() && resource.data.student_id == request.auth.uid);
    }
    match /leave_requests/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('hod') || hasRole('faculty');
    }
    match /student_requests/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('hod') || hasRole('student');
    }

    // Quiz System
    match /quizzes/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty');
    }
    match /quiz/{id} { // Alternative collection name used in some places
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty');
    }
    match /quiz_questions/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('faculty');
    }
    match /quiz_attempts/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.resource.data.student_id == request.auth.uid || hasRole('faculty') || hasRole('admin'));
    }

    // Careers & Alumni
    match /job_postings/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (hasRole('alumni') || hasRole('admin') || hasRole('faculty'));
      allow update, delete: if isSignedIn() && (
        resource.data.alumni_id == request.auth.uid ||
        hasRole('admin')
      );
    }

    // Alumni profiles directory
    match /alumni_profiles/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        resource.data.profile_id == request.auth.uid ||
        hasRole('admin')
      );
    }

    // --- SHARED DRIVE ---
    match /shared_drive/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.uploadedBy == request.auth.uid || hasRole('admin') || hasRole('hod') || hasRole('faculty'));
      allow delete: if hasRole('admin') || hasRole('hod') || hasRole('faculty') || (resource.data.uploadedBy == request.auth.uid);
    }

    // Logs & Auditing
    match /audit_logs/{id} {
      allow read: if hasRole('admin') || hasRole('hod');
      allow write: if isSignedIn();
    }

    // Presence
    match /admin_presence/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == adminId;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if hasRole('admin');
    }
  }
}